<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PRACTICA_RA2.Pages.InfoPage">
    <ScrollView>
        <VerticalStackLayout MinimumWidthRequest="360"
                             MaximumWidthRequest="600" 
                  Padding="10,0,10,20" 
                  Spacing="10">
            <Label 
                Text="Tus estadísticas"
                FontSize="32"
                FontAttributes="Bold"
                Margin="0,0,0,10"/>
            <VerticalStackLayout Spacing="15">
                <Border
                    Style="{StaticResource FondoTarjeta}"
                    StrokeShape="RoundRectangle 20"
                    Padding="20">
                    <VerticalStackLayout>
                        <Label 
                            Style="{StaticResource EtiquetaForm}"
                            Text="Canciones totales"
                            FontSize="14"
                           />
                        <Label 
                            Text="{Binding CancionesTotales}"
                            FontSize="40"
                            FontAttributes="Bold"
                            />
                    </VerticalStackLayout>
                </Border>
                <Border
                    Style="{StaticResource FondoTarjeta}"
                    StrokeShape="RoundRectangle 20"
                    Padding="20">
                    <VerticalStackLayout>
                        <Label 
                            Style="{StaticResource EtiquetaForm}"
                            Text="Canciones favoritas"
                            FontSize="14"/>
                        <Label 
                            Text="{Binding CancionesFavoritas}"
                            FontSize="40"
                            FontAttributes="Bold"
                            TextColor="#1DB954" />
                    </VerticalStackLayout>
                </Border>
                <Border
                    Style="{StaticResource FondoTarjeta}"
                    StrokeShape="RoundRectangle 20"
                    Padding="20">

                    <VerticalStackLayout>
                        <Label 
                            Style="{StaticResource EtiquetaForm}"
                            Text="Artistas escuchados"
                            FontSize="14"/>

                        <Label 
                            Text="{Binding ArtistasTotales}"
                            FontSize="40"
                            FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
            <Button
                Text="Volver al inicio"
                Clicked="OnRegresarClicked"
                Margin="0,30,0,0"
                Style="{StaticResource BotonMenosRedondoSecundario}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>