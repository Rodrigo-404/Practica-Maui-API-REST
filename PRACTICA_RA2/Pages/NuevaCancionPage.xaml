<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PRACTICA_RA2.Pages.NuevaCancionPage">
    <Grid RowDefinitions="auto, *" 
          RowSpacing="30" 
          MinimumWidthRequest="360">
        <Label Grid.Row="0"
               Text="Crear una canción"
               FontSize="30"
               FontAttributes="Bold"
               MaximumWidthRequest="620"
               Padding="10, 0, 10, 0"
               />
        <Grid Grid.Row="1" 
              RowDefinitions="auto, *"
              RowSpacing="10">
            <Button Grid.Row="0" 
                    Style="{StaticResource BotonMenosRedondoApagado}"
                    HorizontalOptions="Center"
                    Text="Selecciona la imagen de la portada"
                    Clicked="OnPickerClicked"/>
            <ScrollView  Grid.Row="1" Padding="10, 0, 10, 50">
                <VerticalStackLayout Spacing="20" 
                                     MaximumWidthRequest="600">
                    <VerticalStackLayout Spacing="5">
                        <Border WidthRequest="250"
                                HeightRequest="250"
                                StrokeShape="RoundRectangle, 10"
                                StrokeThickness="0">
                            <Image Source="{Binding UrlPortada}" 
                                   Aspect= "AspectFill"/>
                        </Border>
                    </VerticalStackLayout>
                    <VerticalStackLayout Spacing="5">
                        <Label Style="{StaticResource EtiquetaForm}"
                               Text="Introduce el título" />
                        <Entry Placeholder="Título" 
                               Text="{Binding Titulo}"/>
                    </VerticalStackLayout>
                    <VerticalStackLayout Spacing="5">
                        <Label Style="{StaticResource EtiquetaForm}"
                               Text="Introduce los artistas" />
                        <VerticalStackLayout x:Name="ContenedorArtistas" 
                                            Spacing="10">
                            <Grid ColumnDefinitions="*, auto" ColumnSpacing="10">
                                <Entry Grid.Column="0"
                                       Placeholder="Nombre del artista" />
                                <Button Grid.Column="1"
                                        Style="{StaticResource BotonRedondo}"
                                        Text="+" 
                                        WidthRequest="0" 
                                        HeightRequest="0"
                                        Clicked="AgregarArtista"/>
                            </Grid>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                    <VerticalStackLayout Spacing="5">
                        <Label Style="{StaticResource EtiquetaForm}"
                               Text="Introduce la duración" />
                        <HorizontalStackLayout Spacing="10">
                            <Entry x:Name="minutosEntry" 
                                   WidthRequest="50" 
                                   Placeholder="MM" 
                                   Keyboard="Numeric" 
                                   HorizontalTextAlignment="Center"/>
                            <Label Text=":" 
                                   VerticalOptions="Center"/>
                            <Entry x:Name="segundosEntry" 
                                   WidthRequest="50" 
                                   Placeholder="SS" 
                                   Keyboard="Numeric"
                                   HorizontalTextAlignment="Center"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                    <VerticalStackLayout Spacing="5">
                        <Button Style="{StaticResource BotonMenosRedondo}"
                                Clicked="OnGuardarClicked" 
                                Text="Guardar cancion"/>
                        <Button Style="{StaticResource BotonMenosRedondoApagado}"
                                Clicked="OnCancelarClicked" 
                                Text="Cancelar cancion"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Grid>
</ContentPage>